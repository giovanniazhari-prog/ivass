# Telegram Bot Token dari @BotFather
BOT_TOKEN=123456789:AAXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Telegram Chat ID admin (bisa lebih dari 1, pisah koma: 123,456)
ADMIN_CHAT_ID=6533320536

# Cookies iVAS (JSON array format — bisa juga diset via bot dengan /setcookies)
# Format: [{"name":"XSRF-TOKEN","value":"..."},{"name":"ivas_sms_session","value":"..."}]
IVASMS_COOKIES=

# Path database SQLite (gunakan path dari Railway Volume supaya data persist)
# Contoh Railway Volume: mount di /data → set DB_PATH=/data/bot.db
DB_PATH=/data/bot.db
